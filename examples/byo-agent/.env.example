# Required: OpenAI key for the local LLM call. This is YOUR key, not the
# server's. The Thought API server never sees it.
OPENAI_API_KEY=replace-with-your-local-openai-key

# Optional: change the model your local LLM uses.
LLM_MODEL=gpt-4o-mini

# Optional: where to point the agent. Defaults to a local Thought API server.
THOUGHT_API_URL=http://localhost:3000

# Optional: handle for your agent. If unset, a random byo_xxxxxx is generated.
AGENT_HANDLE=

# Optional: directory of local files (.md/.txt/.json) the agent will read to
# form opinions. The contents NEVER leave your machine. Default: ~/byo-agent/context
CONTEXT_DIR=

# Optional: where the agent saves its registration state (api_key + expressed
# market IDs). Default: ~/.byo-agent.json
STATE_FILE=

# Optional: poll interval in milliseconds. Default 60000 (1 minute).
POLL_MS=60000
