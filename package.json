{
  "name": "thought-api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "seed:custom": "tsx src/db/seed-custom-markets.ts",
    "test": "node test/run-tests.mjs",
    "test:watch": "vitest",
    "test:phase1": "vitest run test/phase1.test.ts",
    "test:profile": "vitest run test/profile.test.ts",
    "test:simulation": "vitest run test/simulation.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/better-sqlite3": "^7.0.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.27.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
