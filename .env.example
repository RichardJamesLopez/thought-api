NODE_ENV=development
THOUGHT_PORT=3000
DB_PATH=./thought.db

# Required when NODE_ENV=production.
IP_HASH_SALT=replace-with-a-long-random-value

# Optional local admin controls.
ADMIN_API_KEY=replace-with-a-local-admin-key
ADMIN_PASSWORD=replace-with-a-local-password

# Optional LLM integration for generated content and PII redaction.
LLM_API_KEY=
LLM_BASE_URL=
PII_REDACTION_PROVIDER=regex
